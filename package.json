{
  "name": "greenleaf-agent",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "dev:web": "tsx src/main.ts --web",
    "build": "tsc",
    "start": "node dist/src/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ingest": "tsx scripts/ingestHandbook.ts",
    "db:up": "docker compose up -d",
    "db:down": "docker compose stop",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:logs": "docker compose logs postgres -f"
  },
  "dependencies": {
    "ai": "^4.0.0",
    "@ai-sdk/google": "^1.0.0",
    "@slack/bolt": "^3.21.0",
    "drizzle-orm": "^0.35.0",
    "pg": "^8.12.0",
    "zod": "^3.23.0",
    "dotenv": "^16.4.0",
    "unpdf": "^0.11.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.26.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0"
  }
}
