# ── LLM ────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ── Database ────────────────────────────────────────
DATABASE_URL=postgresql://greenleaf:greenleaf_dev@localhost:5432/greenleaf_agent

# ── Slack (leave empty to run in CLI mode) ──────────
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_APP_TOKEN=xapp-your-token-here

# ── Data Paths ──────────────────────────────────────
HANDBOOK_PATH=./data/handbook_clean.txt
HOLIDAYS_CACHE_PATH=./data/holidays_cache.json

# ── Settings ────────────────────────────────────────
HOLIDAY_SUBDIVISION=CH-BS
RAG_CONFIDENCE_THRESHOLD=0.35
RAG_TOP_K=3
MAX_SESSION_AGE_HOURS=24
LOG_LEVEL=info
